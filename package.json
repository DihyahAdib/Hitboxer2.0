{
	"name": "hitboxer2.0",
	"private": true,
	"author": "NoCapStudios",
	"version": "3.1.6",
	"type": "module",
	"main": "electron/main.js",
	"description": "A hitbox creation tool",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5174 && cross-env NODE_ENV=development electron .\"",
		"electron:build": "npm run build && electron-builder",
		"dist:win": "npm run build && electron-builder --win nsis",
		"dist:mac": "npm run build && electron-builder --mac dmg zip",
		"dist:linux": "npm run build && electron-builder --linux AppImage",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint ."
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.0",
		"@eslint/js": "^9.39.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.49.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@types/node": "^24",
		"concurrently": "^9.2.1",
		"electron": "^39.2.7",
		"electron-builder": "^26.8.1",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^16.5.0",
		"prettier": "^3.7.4",
		"prettier-plugin-svelte": "^3.4.0",
		"svelte": "^5.45.6",
		"svelte-check": "^4.3.4",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.48.1",
		"vite": "^7.2.6",
		"wait-on": "^9.0.3"
	},
	"build": {
		"appId": "com.hitboxer.app",
		"productName": "Hitboxer",
		"files": [
			"build/**/*",
			"electron/**/*",
			"node_modules/**/*"
		],
		"win": {
			"target": [
				{
					"target": "nsis",
					"arch": [
						"x64"
					]
				}
			],
			"icon": "static/icon.ico"
		},
		"mac": {
			"target": [
				"dmg",
				"zip"
			],
			"icon": "static/icon.icns"
		},
		"linux": {
			"target": "AppImage",
			"icon": "static/icon.png"
		},
		"nsis": {
			"oneClick": false,
			"allowToChangeInstallationDirectory": true
		},
		"directories": {
			"buildResources": "assets",
			"output": "release"
		}
	},
	"dependencies": {
		"cross-env": "^10.1.0",
		"electron-store": "^11.0.2",
		"gsap": "^3.14.2",
		"lucide-svelte": "^0.562.0"
	}
}